# Database Connection (when running outside docker, use localhost. Inside docker, use db)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/langapp

# Security & JWT Tokens
SECRET_KEY=generate-a-long-random-32-byte-key-here
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Third-party Services (Leave blank to use mock engines during development)
GROQ_API_KEY=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Cloudflare R2 / S3 Storage (Leave blank to fallback to local directory storage)
CLOUDFLARE_R2_BUCKET=
CLOUDFLARE_R2_ACCESS_KEY=
CLOUDFLARE_R2_SECRET_KEY=
CLOUDFLARE_R2_ENDPOINT=

# Next.js Public Config
NEXT_PUBLIC_API_URL=http://localhost:8000
